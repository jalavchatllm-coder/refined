# Supabase (обязательно)
# Получите из https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Google Gemini API (для Edge Functions - устанавливается в Supabase Secrets)
# НЕ указывайте здесь, используйте: supabase secrets set API_KEY=your-key
# API_KEY=your-gemini-api-key

# RuBERT URL (для Edge Functions - устанавливается в Supabase Secrets)
# supabase secrets set RUBERT_URL=https://greeta-ege-essay-grader.hf.space
